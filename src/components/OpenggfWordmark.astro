---
// OpenGGF wordmark (Sonic 2 title card) — plain WHITE text in the Jacked font (the
// real S2 title-card font). The straight-down black shadow is applied by the consumer
// (.tc-zone filter), matching the zig-zag teeth shadow direction.
// (Jacked is registered in tokens.css; Lilita One is a rounded fallback.)
import '@fontsource/lilita-one';
---
<svg class="ggf" viewBox="0 0 640 160" role="img" aria-label="OpenGGF" xmlns="http://www.w3.org/2000/svg">
  <text x="320" y="124" fill="#fff"
        font-family="'Jacked', 'Lilita One', system-ui, sans-serif" font-size="128"
        text-anchor="middle">OpenGGF</text>
</svg>
<style>
  .ggf { display: block; width: 100%; height: auto; overflow: visible; }
</style>
