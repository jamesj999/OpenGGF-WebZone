---
// Sonic 1 title card: black bg, "OpenGGF" in white serif (Schola) aligned over a solid
// lavender blob, with "VER <short>" (where ACT sits) on the blob. No "ZONE". Version is
// pruned to major.minor; if it can't be parsed, the VER label + number are hidden.
import { shortVersion } from '../lib/releases';
interface Props { version: { label: string; isPre: boolean } | null; }
const { version } = Astro.props;
const ver = shortVersion(version);
---
<section class="s1" data-hero="s1" aria-label="OpenGGF — Open-Source Sonic Engine">
  <div class="s1-stage">
    <div class="s1-blob" aria-hidden="true"></div>
    <h1 class="s1-name">OpenGGF</h1>
    {ver && <div class="s1-ver"><span>VER</span><b>{ver}</b></div>}
  </div>
  <p class="s1-tagline">Open-Source Sonic Engine</p>
  <div class="s1-ctas">
    <a class="s1-btn p" href="/#download">⬇ Download</a>
    <a class="s1-btn s" href="/docs">Read the docs</a>
  </div>
</section>

<style>
  .s1 { position: relative; width: 100%; height: clamp(480px, 84vh, 820px);
    overflow: hidden; background: #000; isolation: isolate;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: clamp(30px, 7vh, 80px); }

  /* stage shrinks to the wordmark so the blob can be aligned over its right side */
  .s1-stage { position: relative; display: inline-block; }

  .s1-name {
    position: relative; z-index: 2; margin: 0; text-transform: uppercase;
    font-family: var(--font-s1-text); font-weight: 700; color: #fff;
    font-size: clamp(40px, 8vw, 96px); letter-spacing: 2px; line-height: 1;
    animation: s1-inL .5s ease-out both;
  }
  /* lavender organic blob to the lower-right; the wordmark's right edge just touches it */
  .s1-blob {
    position: absolute; z-index: 0; right: -6%; top: 66%;
    width: 38%; aspect-ratio: 1.05;
    transform: rotate(-12deg);
    background: #9a9ae6; border-radius: 62% 38% 56% 44% / 58% 46% 54% 42%;
    animation: s1-pop .45s ease-out .2s both;
  }
  /* VER + pruned version on the blob, BELOW the wordmark (where ACT sits) */
  .s1-ver {
    position: absolute; z-index: 3; right: 0; top: 96%;
    width: 34%; display: flex; flex-direction: column; align-items: center; line-height: 1;
    animation: s1-inUp .45s ease-out .3s both;
  }
  .s1-ver span { font-family: var(--font-s1-text); font-weight: 700; color: #fff; font-size: clamp(13px, 1.5vw, 18px); letter-spacing: 2px; }
  .s1-ver b { font-family: var(--font-s1-text); font-weight: 700; color: var(--ogf-yellow);
    font-size: clamp(26px, 3.2vw, 44px); -webkit-text-stroke: 1px #0007; }

  .s1-tagline {
    font-family: var(--font-black); font-style: italic; font-size: clamp(18px, 3vw, 34px);
    color: #fff; -webkit-text-stroke: 2px var(--ogf-ink); paint-order: stroke fill; text-align: center;
    animation: s1-inR .5s ease-out .34s both;
  }
  .s1-ctas { display: flex; gap: 16px; justify-content: center; animation: s1-inUp .5s ease-out .44s both; }
  .s1-btn { font: 900 clamp(15px,1.8vw,20px) var(--font-body); padding: 15px 30px;
    border: 4px solid #fff; border-radius: 8px; text-decoration: none; box-shadow: 4px 4px 0 rgba(0,0,0,.5); }
  .s1-btn.p { background: var(--ogf-yellow); color: var(--ogf-ink); border-color: var(--ogf-ink); }
  .s1-btn.s { background: #111; color: #fff; }

  @keyframes s1-inL  { from { transform: translateX(-50vw); opacity: 0; } to { transform: none; opacity: 1; } }
  @keyframes s1-inR  { from { transform: translateX(40vw); opacity: 0; } to { transform: none; opacity: 1; } }
  @keyframes s1-inUp { from { transform: translateY(30px); opacity: 0; } to { transform: none; opacity: 1; } }
  @keyframes s1-pop  { from { transform: rotate(-12deg) scale(0); opacity: 0; } to { opacity: 1; } }

  @media (max-width: 640px) { .s1-ctas { flex-direction: column; align-items: center; } }
</style>
