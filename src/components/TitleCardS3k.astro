---
// Sonic 3 & Knuckles title card: black bg, a tall RED vertical banner with "OPEN
// SOURCE" at its base (angular Andes font), next to "OpenGGF" in silver Andes with a
// grey offset shadow + "VER <short>". Banner + wordmark are grouped close together in
// the centre (not edge-bound). No "ZONE". Version pruned to major.minor (hidden if
// unparseable).
import { shortVersion } from '../lib/releases';
interface Props { version: { label: string; isPre: boolean } | null; }
const { version } = Astro.props;
const ver = shortVersion(version);
---
<section class="s3k" data-hero="s3k" aria-label="OpenGGF — Open-Source Sonic Engine">
  <div class="s3k-group">
    <div class="s3k-banner"><span class="s3k-banner-label">OPEN<br />SOURCE</span></div>
    <div class="s3k-text">
      <div class="s3k-name">OpenGGF</div>
      {ver && <div class="s3k-ver"><span>VER</span> <b>{ver}</b></div>}
    </div>
  </div>

  <p class="s3k-tagline">Open-Source Sonic Engine</p>
  <div class="s3k-ctas">
    <a class="s3k-btn p" href="/#download">⬇ Download</a>
    <a class="s3k-btn s" href="/docs">Read the docs</a>
  </div>
</section>

<style>
  .s3k { position: relative; width: 100%; height: clamp(480px, 84vh, 820px);
    overflow: hidden; background: #000; isolation: isolate;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: clamp(28px, 6vh, 64px); }

  /* banner + wordmark grouped right next to each other, centred */
  .s3k-group { display: flex; align-items: center; justify-content: center; gap: clamp(4px, 0.8vw, 12px); }

  .s3k-banner {
    width: clamp(90px, 11vw, 150px); height: clamp(260px, 46vh, 420px);
    background: var(--ogf-red); border: 4px solid var(--ogf-ink);
    display: flex; align-items: flex-end; justify-content: center; padding-bottom: 7%;
    animation: s3k-drop .55s cubic-bezier(.18,.7,.2,1) both;
  }
  /* label NOT in the title font — a plain heavy sans, like a stamped sub-brand */
  .s3k-banner-label { font-family: var(--font-body); font-weight: 900; text-transform: uppercase;
    color: #fff; font-size: clamp(13px, 1.5vw, 20px); letter-spacing: 2px; text-align: center; line-height: 1.2; }

  .s3k-text { display: flex; flex-direction: column; align-items: flex-start; }
  .s3k-name {
    font-family: var(--font-s3k-text); color: #e9e9f2; font-size: clamp(44px, 8vw, 116px);
    line-height: .95; letter-spacing: 2px; padding: 0 .06em;
    /* grey block behind the bottom half of the text (as in the real S3&K card; no shadow) */
    background: linear-gradient(to bottom, transparent 0 52%, #3c3c46 52% 100%);
    animation: s3k-inR .55s ease-out .12s both;
  }
  /* version block aligned to the wordmark's right edge, in a plain heavy sans (NOT the
     title font) — reads as a spec stamp under the silver name */
  .s3k-ver {
    align-self: flex-end; display: inline-flex; align-items: baseline; gap: 8px; margin-top: .18em;
    font-family: var(--font-body); animation: s3k-inR .55s ease-out .24s both;
  }
  .s3k-ver span { color: #fff; font-weight: 900; text-transform: uppercase;
    font-size: clamp(14px, 1.6vw, 22px); letter-spacing: 2px; }
  .s3k-ver b { color: var(--ogf-yellow); font-weight: 900; font-size: clamp(28px, 3.3vw, 46px);
    -webkit-text-stroke: 1px #0006; line-height: 1; }

  .s3k-tagline {
    font-family: var(--font-black); font-style: italic; font-size: clamp(17px, 2.6vw, 32px);
    color: #fff; -webkit-text-stroke: 2px var(--ogf-ink); paint-order: stroke fill; text-align: center;
    animation: s3k-inR .55s ease-out .34s both;
  }
  .s3k-ctas { display: flex; gap: 14px; justify-content: center; animation: s3k-inUp .5s ease-out .44s both; }
  .s3k-btn { font: 900 clamp(14px,1.7vw,19px) var(--font-body); padding: 14px 28px;
    border: 4px solid #fff; border-radius: 8px; text-decoration: none; box-shadow: 4px 4px 0 rgba(0,0,0,.5); }
  .s3k-btn.p { background: var(--ogf-yellow); color: var(--ogf-ink); border-color: var(--ogf-ink); }
  .s3k-btn.s { background: #111; color: #fff; }

  @keyframes s3k-drop { from { transform: translateY(-120%); } to { transform: none; } }
  @keyframes s3k-inR  { from { transform: translateX(40vw); opacity: 0; } to { transform: none; opacity: 1; } }
  @keyframes s3k-inUp { from { transform: translateY(30px); opacity: 0; } to { transform: none; opacity: 1; } }

  @media (max-width: 640px) {
    .s3k-banner { height: clamp(180px, 30vh, 260px); }
    .s3k-name { font-size: clamp(40px, 12vw, 80px); }
    .s3k-ctas { flex-direction: column; align-items: center; }
  }
</style>
